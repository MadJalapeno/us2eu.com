---
layout: base.njk
---

<section id="toc" class="py-20">
  <div class="container mx-auto px-6">
    <div class="mb-16">
      <div class="max-w-6xl mx-auto">

{%- for post in collections.research %}

        <div class="card bg-base-100 shadow-sm border mb-8">

          <div class="card-body">
            <h2 class="card-title">{{ post.data.title }}</h2>
            <p>{{ post.content | excerpt }}</p>
          </div>

          {{ post.content | readingTime }} minute read

          <div class="flex items-center justify-between mt-4 gap-4 px-4 pb-4">

{% if post.data.tags %}
            <div class="flex flex-wrap gap-3 flex-1 text-sm">
{% for tag in post.data.tags %}
              <div class="inline-block bg-blue-100 text-blue-800 text-sm font-medium px-3 py-1 rounded-full">
                {{ tag }}
              </div>
{% endfor %}
            </div>
{% endif %}

            <div class="flex-shrink-0 px-3 py-1.5 rounded text-sm">
              <a href="{{ post.url }}">
                <button class="btn btn-primary">Read Now</button>
              </a>
            </div>
          </div>
        </div>

{%- endfor %}

      </div>
    </div>
  </div>
</section>