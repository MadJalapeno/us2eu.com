---
layout: base.njk
title: Research
pagination:
  data: collections.research
  size: 5
  alias: posts
  reverse: true
---

<section class="py-16 hero-gradient">
  <div class="container mx-auto px-6 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-4">Comprehensive Guides</p>
    <h1 class="text-5xl font-bold mb-6">Our Research</h1>
    <p class="text-base-content/60 text-lg max-w-2xl mx-auto">Everything we've looked into on our journey towards moving to Europe.</p>
  </div>
</section>

<section id="toc" class="py-16 bg-base-100">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto flex flex-col gap-5">

      {%- for post in pagination.items %}
      <div class="card bg-gradient-to-br from-base-100 to-base-200/20 border border-base-content/10 hover:border-base-content/30 transition-colors relative [&:hover_h2]:text-base-content">
        <div class="card-body gap-3">

          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="card-title text-2xl transition-colors leading-snug">
                <a href="{{ post.url }}" class="after:absolute after:inset-0">{{ post.data.title }}</a>
              </h2>
              {% if post.data.date %}
                <span class="text-xs text-base-content/40">{{ post.data.date | dateFilter }}</span>
              {% endif %}
            </div>
            <span class="flex items-center gap-1.5 text-sm text-base-content/50 whitespace-nowrap flex-shrink-0 min-w-[6rem] justify-end mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {{ post.content | readingTime }} min read
            </span>
          </div>

          <p class="text-base-content/65 text-lg leading-relaxed">{{ post.content | excerpt }}</p>

          {% if post.data.tags %}
          <div class="relative z-10 flex flex-wrap items-center gap-2 pt-1">
            {% for tag in post.data.tags %}
              {% if tag != "all" and tag != "research" and tag != "greatescape" %}
                <a href="/tags/{{ tag | slug }}/" class="badge badge-outline badge-sm hover:bg-base-content hover:text-base-100 transition-colors">{{ tag }}</a>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}

        </div>
      </div>
      {%- endfor %}

    </div>

    <!-- Pagination -->
    {% if pagination.pages.length > 1 %}
    <div class="max-w-4xl mx-auto mt-10 flex justify-center items-center gap-2">

      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" class="btn btn-sm btn-outline">← Prev</a>
      {% else %}
        <span class="btn btn-sm btn-outline btn-disabled">← Prev</span>
      {% endif %}

      {% for pageUrl in pagination.hrefs %}
        <a href="{{ pageUrl }}" class="btn btn-sm {% if pageUrl == page.url %}btn-primary{% else %}btn-outline{% endif %}">
          {{ loop.index }}
        </a>
      {% endfor %}

      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" class="btn btn-sm btn-outline">Next →</a>
      {% else %}
        <span class="btn btn-sm btn-outline btn-disabled">Next →</span>
      {% endif %}

    </div>
    {% endif %}

  </div>
</section>
