
{% include "head.njk" %}

<body class="min-h-screen">
{% include "navbar.njk" %}

  <section id="content" class="py-20">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-5 max-w-6xl mx-auto">
        <!-- Main Content Column -->
        <div class="flex-1">
          <div class="mb-16 prose">
            <div class="font-title text-2xl md:text-3xl lg:text-4xl font-bold">
              {{ title }}
            </div>
          </div>

          <div class="mb-16 prose">
{{ content | safe }}
          </div>
        </div>

        <!-- Metadata Sidebar -->
        <div class="lg:w-80 flex-shrink-0">
          <div class="card bg-base-200 shadow-lg sticky top-20">
            <div class="card-body">
              <h2 class="card-title text-lg">Page Info</h2>
              
              <!-- Published Date -->
              {% if date %}
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70">Published</p>
                <p class="text-base">{{ date | dateFilter }}</p>
              </div>
              {% endif %}
              
              <!-- Author -->
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70">Author</p>
                <p class="text-base">{{ site.author }}</p>
              </div>
              
              <!-- Tags -->
              {% if tags %}
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70 mb-2">Tags</p>
                <div class="flex flex-wrap gap-2">
                  {% for tag in tags %}
                    {% if tag != "all" %}
                    <a href="/tags/{{ tag }}/" class="badge badge-primary badge-outline hover:badge-primary transition-all">
                      {{ tag }}
                    </a>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="mx-auto px-6">
    <div class="flex justify-center items-center">
{% if previous %}
    <a href="{{ previous }}">
      <button class="btn btn-soft btn-primary w-32 mr-4">
        Previous 
      </button>
    </a>
{% endif %}

{% if next %}
    <a href="{{ next }}">
      <button class="btn w-32 btn-soft btn-primary">
        Next 
      </button>
    </a>
{% endif %}
  </section>
</div>
{% include "footer.njk" %}

</body>

</html>