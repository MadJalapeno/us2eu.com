
{% include "head.njk" %}

<body class="min-h-screen">
{% include "navbar.njk" %}

  <section id="content" class="py-20">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-5 max-w-6xl mx-auto">
        <!-- Main Content Column -->
        <div class="flex-1">
          <div class="mb-16 prose">
            <div class="font-title text-2xl md:text-3xl lg:text-4xl font-bold">
              {{ title }}
            </div>
          </div>

          <div class="mb-16 prose">
{{ content | safe }}
          </div>
        </div>

        <!-- Metadata Sidebar -->
        <div class="lg:w-80 flex-shrink-0">
          <div class="card bg-base-200 shadow-lg sticky top-20">
            <div class="card-body">
              <h2 class="card-title text-lg">Page Info</h2>
              
              <!-- Published Date -->
              {% if date %}
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70">Published</p>
                <p class="text-base">{{ date | dateFilter }}</p>
              </div>
              {% endif %}
              
              <!-- Author -->
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70">Author</p>
                <p class="text-base">{{ site.author }}</p>
              </div>
              
              <!-- Tags -->
              {% if tags %}
              <div class="py-2">
                <p class="text-sm font-semibold text-base-content/70 mb-2">Tags</p>
                <div class="flex flex-wrap gap-2">
                  {% for tag in tags %}
                    {% if tag != "all" %}
                    <a href="/tags/{{ tag }}/" class="badge badge-primary badge-outline hover:badge-primary transition-all">
                      {{ tag }}
                    </a>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
              {% endif %}

              <!-- AI Disclaimer -->
              {% if "ClaudeAI" in tags %}
              <div class="pt-2 mt-2 border-t border-base-300">
                <div class="flex gap-2 text-xs text-base-content/60">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <p>This page contains content generated with the assistance of Claude AI. Always verify important information with official sources.</p>
                </div>
              </div>
              {% endif %}

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="next" class="mx-auto px-6">
    <div class="flex justify-center items-center">
{% if previous %}
    <a href="{{ previous }}">
      <button class="btn btn-soft btn-primary w-32 mr-4">
        Previous 
      </button>
    </a>
{% endif %}

{% if next %}
    <a href="{{ next }}">
      <button class="btn w-32 btn-soft btn-primary">
        Next 
      </button>
    </a>
{% endif %}
  </section>
</div>
<!-- Image lightbox modal -->
<dialog id="image-modal" class="modal">
  <div class="modal-box max-w-5xl p-4">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <img id="modal-image" src="" alt="" class="w-full h-auto rounded-lg">
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-image');

    document.querySelectorAll('.prose img').forEach(function (img) {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', function () {
        let fullSrc = img.src;
        // Prefer the largest entry from the first <source> in a <picture> element
        const picture = img.closest('picture');
        if (picture) {
          const source = picture.querySelector('source');
          if (source && source.srcset) {
            const largest = source.srcset.split(',').map(s => s.trim()).pop();
            const url = largest.split(' ')[0];
            if (url) fullSrc = url;
          }
        }
        modalImg.src = fullSrc;
        modalImg.alt = img.alt || '';
        modal.showModal();
      });
    });
  });
</script>

{% include "footer.njk" %}

</body>

</html>