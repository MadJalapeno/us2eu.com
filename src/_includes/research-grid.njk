<!--
# _includes/components/research-grid.njk
-->

<section id="research" class="py-20 bg-base-200/40 dark:bg-base-content/5">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <p class="text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-4">{{ research.subtitle }}</p>
            <h2 class="text-5xl font-bold mb-8">{{ research.title }}</h2>
        </div>

        <div class="max-w-6xl mx-auto space-y-8">
            {% for item in research.items %}
            <div class="card bg-base-100 border border-base-content/10 hover:border-base-content/30 transition-colors">
                <div class="card-body p-8">
                    <div class="flex items-start justify-between mb-6">
                        <div class="flex items-center space-x-6">
                            <div class="text-5xl">
                                {{ item.icon }}
                            </div>
                            <div>
                                <h3 class="text-3xl font-bold text-base-content">{{ item.title }}</h3>
                                <div class="text-base text-base-content/60 font-medium">{{ item.lastUpdated }}</div>
                            </div>
                        </div>
                        <div class="badge badge-outline text-xs font-semibold px-3 py-2">{{ item.status.text }}</div>
                    </div>
                    <p class="text-xl mb-6 leading-relaxed">
                        {{ item.description }}
                    </p>
                    <div class="card-actions justify-between items-center">
                        <div class="flex gap-2 flex-wrap">
                            {% for badge in item.badges %}
                            <div class="bg-base-200 text-xs px-2 py-1 rounded">{{ badge }}</div>
                            {% endfor %}
                        </div>
                        <a href="{{ item.link }}" class="btn btn-sm btn-outline">{{ item.buttonText }}</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>