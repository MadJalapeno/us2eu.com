---
# _includes/theme-switcher.njk
---
<div class="fixed bottom-6 right-6 z-50">
    <div class="dropdown dropdown-top dropdown-end">
        <div tabindex="0" role="button" class="btn btn-circle btn-lg btn-primary shadow-2xl animate-pulse">
            🎨
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] p-4 shadow-2xl bg-base-100 rounded-box w-60 border border-base-300">
            {% for theme in site.themes %}
            <li class="{% if not loop.last %}mb-2{% endif %}">
                <input type="radio" name="theme-dropdown" class="theme-controller btn btn-sm btn-block btn-ghost justify-start text-base" aria-label="{{ theme.name }}" value="{{ theme.value }}"/>
            </li>
            {% endfor %}
        </ul>
    </div>
</div>
