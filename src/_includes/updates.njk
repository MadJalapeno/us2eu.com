<!--
# _includes/components/updates.njk
-->

<section id="updates" class="py-20 bg-base-200/30">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <p class="text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-4">Latest</p>
            <h2 class="text-5xl font-bold mb-8">{{ timeline.title }}</h2>
        </div>

        <div class="max-w-3xl mx-auto">
          <div class="space-y-0 border-l-2 border-base-content/20">
            {% for item in timeline.items %}
            <div class="relative pl-8 pb-8">
              <div class="absolute -left-3.5 top-0 w-6 h-6 bg-base-100 border-2 border-base-content/20 rounded-full"></div>
              <div class="pt-1">
                <div class="flex items-start justify-between mb-2">
                  <h3 class="font-bold text-lg">{{ item.title }}</h3>
                  <div class="text-sm text-base-content/60 font-medium">{{ item.date }}</div>
                </div>
                <p class="text-base-content/70">{{ item.description }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
          <div class="mt-12 text-center">
            <a href="#" class="btn btn-outline btn-sm">More updates</a>
          </div>
        </div>
    </div>
</section>