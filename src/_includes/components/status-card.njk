---
# _includes/components/hero.njk
---
<section class="hero min-h-[80vh] relative overflow-hidden">
    <div class="hero-overlay bg-gradient-to-br from-orange-500/10 to-red-500/10"></div>
    <div class="hero-content text-center max-w-6xl relative z-10">
        <div class="max-w-4xl">
            <div class="avatar mb-8 animate-float">
                <div class="w-40 rounded-full bg-gradient-to-br from-blue-400 via-purple-500 to-pink-500 shadow-2xl flex items-center justify-center text-7xl animate-glow">
                    {{ hero.avatar or "👫" }}
                </div>
            </div>
            <h1 class="text-6xl lg:text-7xl font-bold mb-8 leading-tight">
                {{ hero.title | safe }}
            </h1>
            <p class="text-2xl lg:text-3xl max-w-4xl mb-12 leading-relaxed text-base-content/80 font-light">
                {{ hero.subtitle }}
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center">
                {% for button in hero.buttons %}
                <button class="btn {{ button.class }} btn-lg text-lg px-10 {{ button.extraClass }}">
                    {{ button.text }}
                </button>
                {% endfor %}
            </div>
        </div>
    </div>
    <!-- Floating Elements -->
    {% if hero.floatingElements %}
    {% for element in hero.floatingElements %}
    <div class="absolute {{ element.position }} text-{{ element.size }} opacity-20 animate-float" style="animation-delay: {{ element.delay }};">{{ element.emoji }}</div>
    {% endfor %}
    {% endif %}
</section>