        <nav class="relative z-10">
            <div class="grid grid-flow-col gap-8 text-lg">
                <a class="link link-hover hover:text-primary transition-colors font-medium" href="#">Privacy</a>
                <a class="link link-hover hover:text-primary transition-colors font-medium" href="#">About Us</a>
