    <!-- Enhanced Contact Section -->
    <section id="contact" class="py-20">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-5xl font-bold gradient-text mb-4">Want to follow along?</h2>
                <p class="text-2xl text-base-content/70 font-light">
                    We'd love to connect with others going through this journey or who've already made the leap!
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-orange-400 to-red-500 mx-auto rounded-full mt-6"></div>
            </div>
            
            <div class="max-w-3xl mx-auto">
                <div class="card bg-gradient-to-br from-base-100 to-base-200/50 shadow-2xl border border-orange-200/50">
                    <div class="card-body p-10">
                        <div class="text-center mb-8">
                            <div class="text-6xl mb-4">📬</div>
                            <h3 class="text-3xl font-bold mb-4">Get updates when we post new research</h3>
                            <div class="form-control max-w-md mx-auto">
                                <div class="join shadow-2xl">
                                    <input type="email" placeholder="your@email.com" class="input input-bordered input-lg join-item flex-1 text-lg" />
                                    <button class="btn btn-primary btn-lg join-item px-8 text-lg font-semibold">Count me in!</button>
                                </div>
                                <label class="label">
                                    <span class="label-text-alt text-base opacity-70">Just the important stuff, we promise</span>
                                </label>
                            </div>
                        </div>
                        
                        <div class="divider text-lg font-semibold">OR</div>
                        
                        <div class="text-center">
                            <div class="text-5xl mb-4">💌</div>
                            <h3 class="text-3xl font-bold mb-4">Or just say hi!</h3>
                            <p class="text-xl mb-6 text-base-content/80">
                                Going through something similar? Have advice? Just want to chat? We'd love to hear from you.
                            </p>
                            <a href="mailto:hello@yourjourney.com" class="btn btn-outline btn-lg text-lg px-10 hover:btn-secondary transition-all duration-300">
                                📧 hello@yourjourney.com
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

        <!-- Enhanced Footer -->
    <footer class="footer footer-center bg-gradient-to-br from-base-300 to-base-200 text-base-content p-16 relative overflow-hidden">
