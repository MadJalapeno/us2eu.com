<!--
/src/_includes/hero.njk
-->
<section class="hero hero-gradient min-h-screen lg:min-h-[70vh] relative overflow-hidden">
    <div class="hero-content max-w-6xl w-full relative z-10 flex-col lg:flex-row gap-6 lg:gap-12 py-12 lg:py-20 px-4 lg:px-0">
        <div class="flex-1 flex items-center justify-center order-2 lg:order-1">
            <div class="avatar w-full max-w-xs lg:max-w-sm">
                <div class="w-full rounded-2xl grayscale border border-base-content/10 overflow-hidden">
                    <img src="{{ hero.avatar }}" alt=""/>
                </div>
            </div>
        </div>
        <div class="flex-1 text-left order-1 lg:order-2">
            <p class="text-xs lg:text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-2 lg:mb-4">Personal Journey</p>
            <h1 class="text-3xl sm:text-4xl lg:text-6xl font-bold mb-4 lg:mb-6 leading-tight">
                {{ hero.title | safe }}
            </h1>
            <p class="text-base sm:text-lg lg:text-2xl max-w-2xl mb-6 lg:mb-10 leading-relaxed text-base-content/70 font-light">
                {{ hero.subtitle }}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                {% for button in hero.buttons %}
                <a href="{{ button.url }}">
                    <button class="btn {{ button.class }} btn-md text-base px-8">
                        {{ button.text }}
                    </button>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>