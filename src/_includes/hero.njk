<!--
/src/_includes/hero.njk
-->
<section class="hero hero-gradient min-h-[70vh] relative overflow-hidden">
    <div class="hero-content max-w-6xl w-full relative z-10 flex-row gap-12 py-20">
        <div class="flex-1 flex items-center justify-center">
            <div class="avatar w-full max-w-sm">
                <div class="w-full rounded-2xl grayscale border border-base-content/10 overflow-hidden">
                    <img src="{{ hero.avatar }}" alt=""/>
                </div>
            </div>
        </div>
        <div class="flex-1 text-left">
            <p class="text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-4">Personal Journey</p>
            <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
                {{ hero.title | safe }}
            </h1>
            <p class="text-xl lg:text-2xl max-w-2xl mb-10 leading-relaxed text-base-content/70 font-light">
                {{ hero.subtitle }}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                {% for button in hero.buttons %}
                <a href="{{ button.url }}">
                    <button class="btn {{ button.class }} btn-md text-base px-8">
                        {{ button.text }}
                    </button>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>