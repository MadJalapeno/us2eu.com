
<div class="navbar bg-base-100 sticky top-0 z-50 border-b border-base-content/10">
    <div class="navbar-start">
        <div class="dropdown">
            <div tabindex="0" role="button" class="btn btn-ghost btn-circle lg:hidden">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </div>
            <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 border border-base-content/10">
                {% for item in navigation.main %}
                <li><a href="{{ item.url }}" class="text-base font-medium{% if page.url == item.url %} active{% endif %}">{{ item.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
        <div class="flex items-center space-x-3 ml-2">
            <div>
                <div class="text-lg font-bold tracking-tight">
                    <a href="/">{{ site.name }}</a>
                </div>
                <div class="text-xs uppercase tracking-widest text-base-content/50">{{ site.tagline }}</div>
            </div>
        </div>
    </div>

    <div class="navbar-end hidden lg:flex items-center gap-4">
        <ul class="menu menu-horizontal px-1 gap-1">
            {% for item in navigation.main %}
            <li>
                <a href="{{ item.url }}"
                   class="text-base-content/70 hover:text-base-content font-medium text-sm{% if page.url == item.url %} active{% endif %}">
                    {{ item.text }}
                </a>
            </li>
            {% endfor %}
        </ul>
        <a href="mailto:hello@us2eu.com" class="btn btn-sm btn-outline ml-2">Say Hi</a>
    </div>
</div>