---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - post
    - posts
    - tagCloud
permalink: /tags/{{ tag | slug }}/
eleventyComputed:
  title: "Posts tagged '{{ tag }}'"
---

{% include "head.njk" %}

<body class="min-h-screen">
{% include "navbar.njk" %}

<section class="py-16 bg-base-200/40 dark:bg-base-content/5">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto">
      <a href="/tags/" class="text-base-content/60 hover:text-base-content text-sm mb-6 inline-block">← All Tags</a>
      <p class="text-sm font-semibold uppercase tracking-widest text-base-content/40 mb-2">Tag</p>
      <h1 class="text-5xl font-bold mb-4">{{ tag }}</h1>
      <p class="text-lg text-base-content/70">{{ collections[tag].length }} post{{ 's' if collections[tag].length != 1 else '' }} found</p>
    </div>
  </div>
</section>

<section class="py-16 bg-base-100">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto space-y-6">
      <!-- Posts with this tag -->
      {% for post in collections[tag] | reverse %}
        <article class="card bg-base-100 border border-base-content/10 hover:border-base-content/30 transition-colors">
          <div class="card-body">
            <h2 class="card-title text-2xl mb-2">
              <a href="{{ post.url }}" class="hover:text-base-content/70 transition-colors">
                {{ post.data.title }}
              </a>
            </h2>

            <div class="text-base-content/60 text-sm mb-4">
              {{ post.data.date | dateFilter }}
            </div>

            {% if post.content %}
              <p class="text-base-content/70 leading-relaxed mb-4">
                {{ post.content | excerpt }}
              </p>
            {% endif %}

            <!-- Show other tags for this post -->
            {% if post.data.tags and post.data.tags.length > 1 %}
              <div class="flex flex-wrap gap-2 mt-4">
                {% for postTag in post.data.tags %}
                  {% if postTag != "posts" and postTag != tag %}
                    <a href="/tags/{{ postTag | slug }}/"
                       class="badge badge-outline badge-sm hover:bg-base-content hover:text-base-100 transition-colors">
                      {{ postTag }}
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    <!-- Related tags -->
    <div class="max-w-4xl mx-auto mt-16 pt-12 border-t border-base-content/10">
      <h3 class="text-2xl font-bold mb-6">Related Tags</h3>
      <div class="flex flex-wrap gap-3">
        {% set relatedTags = [] %}
        {% for post in collections[tag] %}
          {% if post.data.tags %}
            {% for relatedTag in post.data.tags %}
              {% if relatedTag != "posts" and relatedTag != tag and relatedTag != "" %}
                {% set relatedTags = (relatedTags.push(relatedTag), relatedTags) %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}

        {% set uniqueRelatedTags = relatedTags | unique | sort %}
        {% for relatedTag in uniqueRelatedTags %}
          <a href="/tags/{{ relatedTag | slug }}/"
             class="badge badge-outline hover:bg-base-content hover:text-base-100 transition-colors">
            {{ relatedTag }}
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% include "footer.njk" %}

</body>

</html>